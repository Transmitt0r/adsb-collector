# Telegram bot token (from @BotFather)
BOT_TOKEN=your-telegram-bot-token

# Anthropic API key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Bot's own Postgres password
BOT_DB_PASSWORD=changeme

# TimescaleDB connection (the collector's DB)
COLLECTOR_DATABASE_URL=postgresql://flighttracker:changeme@<nas-ip>:5431/flighttracker

# Your Telegram chat ID — leave empty until you do /start and check logs
ADMIN_CHAT_ID=

# Cron schedule for weekly digest (default: Sunday 8am Europe/Berlin)
# DIGEST_SCHEDULE=0 8 * * 0
