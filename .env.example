# FlightTracker Configuration

# ADS-B data source
ADSB_URL=http://192.168.0.111/tar1090/data/aircraft.json

# Polling interval in seconds
POLL_INTERVAL=5

# Seconds of silence before an aircraft session is considered ended
SESSION_TIMEOUT=300

# PostgreSQL connection
DATABASE_URL=postgresql://flighttracker:changeme@192.168.0.40:5432/flighttracker
